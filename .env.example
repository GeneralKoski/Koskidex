# Koskidex backend configuration.
# Copy to .env and adjust. CLI flags override these values.

# Port the HTTP API listens on.
KOSKIDEX_PORT=7700

# Directory where the WAL and GOB snapshots are persisted.
KOSKIDEX_DATA_DIR=./data

# Bearer token required on every request (except /health).
# Leave empty to disable authentication (NOT recommended in production).
KOSKIDEX_API_KEY=

# Log level: debug | info | warn | error
KOSKIDEX_LOG_LEVEL=info

# Max requests per second per IP. 0 disables rate limiting.
KOSKIDEX_RATE_LIMIT=0

# Allowed CORS origin. "*" allows any origin; set a specific origin in production.
KOSKIDEX_CORS_ORIGIN=*

# TLS (optional). Provide both to serve HTTPS directly.
KOSKIDEX_TLS_CERT=
KOSKIDEX_TLS_KEY=
